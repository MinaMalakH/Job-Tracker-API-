# MongoDB connection URI
MONGO_URL=

# PostgreSQL connection URI
i.e. postgres://user:password@host:port/dbname
POSTGRES_URI=

# Redis connection string
REDIS_URL=redis://localhost:6379

# JWT secrets (generate long random strings)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# OpenAI / Groq API key
OPENAI_API_KEY=

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Gmail recommended) - use app password for security
e.g. EMAIL_USER=you@gmail.com
EMAIL_USER=
EMAIL_PASS=

# Server configuration
PORT=3000
NODE_ENV=development
